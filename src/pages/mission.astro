---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<style>
  .terminal-line {
    font-family: 'JetBrains Mono', monospace;
    opacity: 0;
    animation: fadeIn 0.5s forwards;
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }
  .cursor {
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
  .progress-gradient {
    background: linear-gradient(90deg, #10b981 0%, #059669 100%);
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
  }
</style>

<BaseLayout 
	title="Mission Simulator | Tadpole OS Experience"
	description="Experience a live Tadpole OS mission simulation. See how agents Nine, Tadpole, and Elon coordinate a system-wide security audit."
>
	<main class="relative z-10 max-w-7xl mx-auto px-6 py-24 md:py-32" x-data="{ currentStep: 0, missionActive: false }">
    <!-- Mission Header -->
    <header class="text-center space-y-8 mb-24">
      <p class="text-[10px] font-mono text-emerald-500 uppercase tracking-[0.5em]">Live Prototype</p>
      <h1 class="text-6xl md:text-9xl font-bold tracking-tighter text-white font-outfit leading-[0.9]">
        Mission <span class="text-zinc-700">Simulator</span>
      </h1>
      <p class="text-lg text-zinc-400 max-w-xl mx-auto font-light font-inter">
        Visualize a **Recursive Swarm Engagement**. Witness the orchestration of the **Neural Context Bus** during a sovereign security audit.
      </p>
    </header>

    <!-- Simulator Terminal -->
    <section class="max-w-4xl mx-auto glass-surface rounded-3xl border border-white/5 overflow-hidden shadow-2xl relative">
      <div class="absolute inset-0 bg-emerald-500/5 blur-3xl pointer-events-none"></div>
      
      <!-- Window Controls -->
      <div class="bg-white/5 border-b border-white/5 px-6 py-4 flex items-center justify-between">
        <div class="flex gap-2">
          <div class="w-2 h-2 rounded-full bg-red-500/20"></div>
          <div class="w-2 h-2 rounded-full bg-yellow-500/20"></div>
          <div class="w-2 h-2 rounded-full bg-emerald-500/40"></div>
        </div>
        <div class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">Tadpole-OS-v2026.exe</div>
        <div class="w-4"></div>
      </div>

      <!-- Console Area -->
      <div class="p-8 md:p-12 space-y-12 bg-black/40 min-h-[500px] relative">
        
        <!-- START SCREEN -->
        <div x-show="currentStep === 0" class="flex flex-col items-center justify-center space-y-8 py-12">
          <div class="w-24 h-24 rounded-full border border-emerald-500/20 flex items-center justify-center bg-emerald-500/5 animate-pulse">
            <span class="text-4xl text-emerald-500">🐸</span>
          </div>
          <div class="text-center">
            <h3 class="text-2xl font-bold text-white mb-2 uppercase tracking-tighter">Initiate Handshake</h3>
            <p class="text-zinc-500 text-sm font-mono tracking-widest uppercase">Awaiting NEURAL_TOKEN...</p>
          </div>
          <button 
            @click="currentStep = 1"
            class="px-12 py-4 bg-white text-zinc-950 font-bold rounded-xl hover:bg-zinc-200 transition-all hover:scale-105 active:scale-95"
          >
            START MISSION
          </button>
        </div>

        <!-- STEP 1: Handshake -->
        <div x-show="currentStep === 1" class="space-y-6">
          <div class="terminal-line text-zinc-500 text-xs">PS C:\Tadpole> .\initiate_handshake.ps1</div>
          <div class="terminal-line text-emerald-500 font-bold">✅ NEURAL_TOKEN: VERIFIED</div>
          <div class="terminal-line text-white">📡 Handshake success. System Online.</div>
          <div class="terminal-line text-zinc-600 mt-4 italic">"Welcome back, Overlord. Domestic agent Tadpole (ID 2) is ready."</div>
          <button @click="currentStep = 2" class="mt-8 px-8 py-3 glass-surface text-white text-xs font-bold rounded-lg border border-white/10 hover:border-white/20">Next Phase: Discovery</button>
        </div>

        <!-- STEP 2: Discovery -->
        <div x-show="currentStep === 2" class="space-y-8">
          <div class="relative group">
            <div class="absolute inset-0 bg-emerald-500/10 blur-3xl opacity-50"></div>
            <img src="/AI-Tadpole-OS-Marketing/assets/real_os_dashboard.png" alt="OS Dashboard" class="rounded-xl border border-white/10 shadow-2xl relative z-10" />
            <div class="absolute bottom-4 right-4 glass-surface px-3 py-1 rounded-full text-[8px] font-mono text-emerald-400 uppercase tracking-widest z-20">Live Interface</div>
          </div>
          <div class="terminal-line text-zinc-600 text-[10px] leading-relaxed mt-4">
            [SYS] Neural Context Bus initialized. <br/>
            [SYS] Bunker Discovery: 14 Nodes found (mDNS). <br/>
            [Tadpole] Dispatching Recursive Swarm mission to Alpha Node: Elon (ID 3).
          </div>
          <button @click="currentStep = 3" class="mt-8 px-8 py-3 glass-surface text-white text-xs font-bold rounded-lg border border-white/10">Next Phase: Recruitment</button>
        </div>

        <!-- STEP 3: Recruitment -->
        <div x-show="currentStep === 3" class="space-y-8">
          <div class="relative group">
            <div class="absolute inset-0 bg-emerald-500/10 blur-3xl opacity-50"></div>
            <img src="/AI-Tadpole-OS-Marketing/assets/real_os_nodes.png" alt="OS Hierarchy" class="rounded-xl border border-white/10 shadow-2xl relative z-10" />
          </div>
          <div class="terminal-line text-zinc-500 text-[10px] mt-4">
             [Tadpole] "Elon, coordinate swarm for 'server-rs' audit." <br/>
             [Elon] "Strategic intent received. Initiating Recursive Swarm on Silicon Horizon."
          </div>
          <button @click="currentStep = 4" class="mt-8 px-8 py-3 bg-emerald-500 text-zinc-950 text-xs font-bold rounded-lg border border-emerald-400 hover:bg-emerald-400">Launch Execution</button>
        </div>

        <!-- STEP 4: Execution -->
        <div x-show="currentStep === 4" class="space-y-8">
          <div class="relative group">
            <div class="absolute inset-0 bg-emerald-500/10 blur-3xl opacity-50"></div>
            <img src="/AI-Tadpole-OS-Marketing/assets/real_os_oversight.png" alt="OS Oversight" class="rounded-xl border border-white/10 shadow-2xl relative z-10" />
          </div>
          <div class="terminal-line text-emerald-500/60 font-mono text-[10px] mt-4">
            Scanning Capabilities ... [Sapphire Shield: ENGAGED] <br/>
            Validating Neural Vault integrity ... [AES-256: OK] <br/>
            Synthesizing Autonomous Continuity ... 100%
          </div>
          <button @click="currentStep = 5" class="mt-8 px-8 py-3 bg-white text-zinc-950 text-xs font-bold rounded-lg hover:bg-zinc-200">View Final Report</button>
        </div>

        <!-- STEP 5: Results -->
        <div x-show="currentStep === 5" class="space-y-8 animate-in zoom-in duration-500">
          <div class="p-8 glass-surface rounded-3xl border border-white/10 space-y-8 text-center bg-white/[0.02]">
            <div class="w-16 h-16 mx-auto bg-emerald-500/10 rounded-full flex items-center justify-center text-2xl border border-emerald-500/20">🏆</div>
            <div class="space-y-2">
              <h3 class="text-2xl font-bold text-white tracking-widest uppercase">Executive Risk Report</h3>
              <p class="text-emerald-400 font-mono text-xs uppercase tracking-[0.2em]">Archive: Vault-1/2026-Audit.md</p>
            </div>
            <div class="text-left py-6 border-t border-b border-white/5 space-y-4">
              <div class="flex justify-between text-[10px] font-mono">
                <span class="text-zinc-500">TIME TO RESULT:</span>
                <span class="text-white">12.4 Seconds</span>
              </div>
              <div class="flex justify-between text-[10px] font-mono">
                <span class="text-zinc-500">OPERATIONAL SAVINGS:</span>
                <span class="text-emerald-500">+18 Man-Hours</span>
              </div>
              <div class="flex justify-between text-[10px] font-mono">
                <span class="text-zinc-500">STATUS:</span>
                <span class="text-white">SOVEREIGNTY SECURED</span>
              </div>
            </div>
            <p class="text-zinc-500 text-xs font-light italic">
              "The results are reconciled on the Silicon Horizon. Tadpole OS is ready to evolve your company into the Big Frog."
            </p>
            <div class="flex gap-4 justify-center">
              <a href="./" class="px-6 py-3 glass-surface text-white text-[10px] font-bold uppercase rounded-lg border border-white/10">Return Home</a>
              <button @click="currentStep = 0" class="px-6 py-3 bg-emerald-500 text-zinc-950 text-[10px] font-bold uppercase rounded-lg">Run New Simulation</button>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Additional Context (GEO/Authority) -->
    <section class="mt-24 max-w-4xl mx-auto grid md:grid-cols-2 gap-12">
      <div class="space-y-4">
        <h4 class="text-white font-bold uppercase tracking-widest text-xs">Mission Integrity</h4>
        <p class="text-zinc-500 text-sm font-light">
          Unlike generic AI chat, Tadpole OS runs deterministic missions. Every step is logged on the **Neural Context Bus**, ensuring that multiple agents can coordinate with surgical precision.
        </p>
      </div>
      <div class="space-y-4">
        <h4 class="text-white font-bold uppercase tracking-widest text-xs">Silicon Horizon</h4>
        <p class="text-zinc-500 text-sm font-light">
          When missions reach the "Silicon Horizon," the engine merges specialists' tactical findings into a single strategic report for your review—protecting your EBITDA through autonomous growth.
        </p>
      </div>
    </section>

	</main>

  <script is:inline src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</BaseLayout>
