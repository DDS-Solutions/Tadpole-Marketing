---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="Tadpole OS | Secure, Local-First Multi-Agent Swarms"
	description="The high-performance, autonomous engine for sovereign intelligence. Built for SMBs who demand scalability and absolute data control."
>
	<main class="relative z-10 max-w-7xl mx-auto px-6 py-24 md:py-32">
		<!-- Hero Section -->
		<section class="text-center space-y-8 relative">
      <!-- Hero Glow Aura -->
      <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-96 h-96 bg-emerald-500/5 blur-[120px] pointer-events-none"></div>
      
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-[10px] font-mono tracking-widest text-emerald-400 uppercase animate-pulse">
				<span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_12px_rgba(34,197,94,0.8)]"></span>
				Engine Status: Alpha-1 Active
			</div>
			
			<h1 class="text-6xl md:text-9xl font-bold tracking-tighter text-white leading-[0.9] font-outfit">
				The Sovereign Engine for <br/>
        <span class="text-zinc-700">Autonomous Growth</span>
			</h1>
			
			<p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto font-light leading-relaxed font-inter">
				Tadpole OS is the high-performance, local-first runtime for **autonomous multi-agent swarms**. 
				Powered by **Recursive Swarm Protocols**, it delivers absolute data sovereignty and hierarchical intelligence for the modern enterprise.
			</p>
			
			<div class="flex flex-col sm:flex-row items-center justify-center gap-6 pt-12">
				<a href="https://github.com/DDS-Solutions/AI-TadPole-OS" class="w-full sm:w-auto px-10 py-5 bg-white text-zinc-950 font-bold rounded-2xl hover:bg-zinc-200 transition-all hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(255,255,255,0.15)] text-sm tracking-tight">
					Fork on GitHub
				</a>
				<a href="mission" class="w-full sm:w-auto px-10 py-5 bg-emerald-500 text-zinc-950 font-bold rounded-2xl hover:bg-emerald-400 transition-all hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(16,185,129,0.3)] text-sm tracking-tight">
					Start Mission
				</a>
				<a href="how-it-works" class="w-full sm:w-auto px-10 py-5 glass-surface text-white font-bold rounded-2xl hover:bg-white/10 transition-all hover:scale-105 active:scale-95 text-sm tracking-tight border-white/20">
					How It Works
				</a>
			</div>
		</section>

    <!-- Metamorphosis Workflow Section -->
    <section class="py-32 border-t border-white/5 mt-32">
      <div class="text-center space-y-4 mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight">The Metamorphosis</h2>
        <p class="text-zinc-500 font-mono text-xs uppercase tracking-[0.3em]">From Observer to Market Leader</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-12 relative">
        <!-- Connecting Line (Desktop) -->
        <div class="hidden md:block absolute top-24 left-0 w-full h-px bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent -z-10"></div>
        
        <!-- Phase 1 -->
        <div class="space-y-6 text-center group">
          <div class="w-24 h-24 mx-auto rounded-full bg-zinc-900 border-2 border-emerald-500/20 flex items-center justify-center glass-surface group-hover:border-emerald-500 transition-all duration-500 relative">
            <div class="absolute inset-0 rounded-full bg-emerald-500/10 blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <span class="text-2xl">🥚</span>
          </div>
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-white">Phase 1: Tadpole</h3>
            <p class="text-xs font-mono text-emerald-400/60 uppercase tracking-widest">Parallel Assistance</p>
            <p class="text-sm text-zinc-500 leading-relaxed font-light">Runs in private isolation. Observes, documents, and automates repetitive tasks in a zero-risk sandbox.</p>
          </div>
        </div>

        <!-- Phase 2 -->
        <div class="space-y-6 text-center group">
          <div class="w-24 h-24 mx-auto rounded-full bg-zinc-900 border-2 border-emerald-500/40 flex items-center justify-center glass-surface group-hover:border-emerald-500 transition-all duration-500 relative">
            <div class="absolute inset-0 rounded-full bg-emerald-500/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <span class="text-2xl">🐸</span>
          </div>
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-white">Phase 2: Metamorphosis</h3>
            <p class="text-xs font-mono text-emerald-400/80 uppercase tracking-widest">Active Onboarding</p>
            <p class="text-sm text-zinc-500 leading-relaxed font-light">The OS integrates with company domains. Specialists solve supply chain, sales, and HR bottlenecks.</p>
          </div>
        </div>

        <!-- Phase 3 -->
        <div class="space-y-6 text-center group">
          <div class="w-24 h-24 mx-auto rounded-full bg-emerald-500 border-2 border-emerald-400 flex items-center justify-center shadow-[0_0_30px_rgba(16,185,129,0.3)] group-hover:scale-110 transition-transform duration-500 relative">
            <span class="text-2xl">👑</span>
          </div>
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-white">Phase 3: Big Frog</h3>
            <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest italic">Sovereign Mastery</p>
            <p class="text-sm text-zinc-500 leading-relaxed font-light">Full-scale **Autonomous Continuity** swarms. **Sovereign Strategic Intent Injection** ensures zero context decay across recursive agent clusters.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- RREST Excellence Section -->
    <section class="py-32 border-t border-white/5 mt-32 relative overflow-hidden">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-[10px] font-mono tracking-widest text-emerald-400 uppercase">
            Technical Excellence
          </div>
          <h2 class="text-4xl md:text-6xl font-bold text-white tracking-tight">REST Standards & <br/>Standardized Observability</h2>
          <p class="text-zinc-400 text-lg font-light leading-relaxed">
            We don't just build APIs; we build discoverable ecosystems. Tadpole OS implements the **HATEOAS** pattern (REST Level 3), enabling self-discovery of related actions. Every failure is reported via **RFC 9457 (Problem Details)**, ensuring your developers never have to guess.
          </p>
          <ul class="space-y-4">
            <li class="flex items-center gap-3 text-zinc-500">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              Hypermedia as the Engine of Application State
            </li>
            <li class="flex items-center gap-3 text-zinc-500">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              RFC 9457 Machine-Readable Error Envelopes
            </li>
            <li class="flex items-center gap-3 text-zinc-500">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              Reactive Infrastructure with sub-second latency
            </li>
          </ul>
        </div>
        <div class="relative group">
          <div class="absolute inset-0 bg-emerald-500/10 blur-3xl rounded-full opacity-50 group-hover:opacity-100 transition-opacity"></div>
          <img src="/Tadpole-Marketing/assets/neural_map_infographic_1773353269093.png" alt="Neural Map" class="rounded-2xl border border-white/10 shadow-2xl relative z-10 hover:scale-[1.02] transition-transform duration-500" />
        </div>
      </div>
    </section>

    <!-- Neural Interaction Section -->
    <section class="py-32 border-t border-white/5 mt-32">
      <div class="text-center max-w-3xl mx-auto space-y-8 mb-20">
        <h2 class="text-4xl md:text-6xl font-bold text-white tracking-tight">Neural Voice <br/>& Sovereign Synthesis</h2>
        <p class="text-zinc-400 text-lg font-light">
          Talk to your swarm without the cloud overhead. Our **Sovereign TTS (Piper)** and **STT (Whisper)** integration delivers near-zero latency interaction.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="p-8 glass-surface rounded-3xl space-y-4">
          <div class="w-12 h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center">🎙️</div>
          <h3 class="text-xl font-bold text-white">Sovereign STT</h3>
          <p class="text-sm text-zinc-500">Local neural transcription for privacy-first intent capture. No external API calls required.</p>
        </div>
        <div class="p-8 glass-surface rounded-3xl space-y-4">
          <div class="w-12 h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center">🧠</div>
          <h3 class="text-xl font-bold text-white">Sovereign TTS</h3>
          <p class="text-sm text-zinc-500">Fast, local voice synthesis powered by Piper. Human-grade vocal interaction at the edge.</p>
        </div>
        <div class="p-8 glass-surface rounded-3xl space-y-4">
          <div class="w-12 h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center">⚡</div>
          <h3 class="text-xl font-bold text-white">Neural VAD</h3>
          <p class="text-sm text-zinc-500">Intelligent Voice Activity Detection (Silero) for seamless, hands-free swarm orchestration.</p>
        </div>
      </div>    <!-- Distributed Bunkers Section -->
    <section class="py-32 border-t border-white/5 mt-32 relative">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="relative order-2 md:order-1 group">
          <div class="absolute inset-0 bg-emerald-500/10 blur-3xl rounded-full opacity-50 group-hover:opacity-100 transition-opacity"></div>
          <img src="/Tadpole-Marketing/assets/distributed_bunker_nodes_1773353300493.png" alt="Distributed Bunkers" class="rounded-2xl border border-white/10 shadow-2xl relative z-10 hover:scale-[1.02] transition-transform duration-500" />
        </div>
        <div class="space-y-8 order-1 md:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-[10px] font-mono tracking-widest text-emerald-400 uppercase">
            Scalability & Privacy
          </div>
          <h2 class="text-4xl md:text-6xl font-bold text-white tracking-tight">Bunker Shield & <br/>Zero-Conf Swarms</h2>
          <p class="text-zinc-400 text-lg font-light leading-relaxed">
            Expand your collective intelligence across the local network. Our **Bunker Discovery** protocol leverages mDNS to automatically scavenge secondary nodes for hardware-accelerated swarming.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="p-4 border border-white/5 rounded-xl bg-zinc-900/50">
              <h4 class="text-white font-bold mb-1">Privacy Mode (Shield)</h4>
              <p class="text-xs text-zinc-500">Explicitly block all external cloud traffic for total air-gapped sovereignty.</p>
            </div>
            <div class="p-4 border border-white/5 rounded-xl bg-zinc-900/50">
              <h4 class="text-white font-bold mb-1">Zero-Conf mDNS</h4>
              <p class="text-xs text-zinc-500">Automatic local discovery of and pairing with Bunker nodes.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Template Ecosystem Section -->
    <section class="py-32 border-t border-white/5 mt-32">
       <div class="flex flex-col md:flex-row gap-16 items-center">
        <div class="flex-1 space-y-8">
          <h2 class="text-4xl md:text-6xl font-bold text-white tracking-tight">The Swarm Template <br/>Ecosystem</h2>
          <p class="text-zinc-400 text-lg font-light">
            Don't start from scratch. Browse our GitHub-native marketplace for industry-specific swarms. Deploy Legal, Healthcare, or Finance specialists in seconds.
          </p>
          <div class="space-y-6">
            <div class="flex gap-4 p-4 glass-surface rounded-2xl border-emerald-500/20">
              <div class="text-2xl">🛡️</div>
              <div>
                <h4 class="text-white font-bold">Sapphire Shield Protection</h4>
                <p class="text-sm text-zinc-500">Zero-Trust capability scanning for every installed template.</p>
              </div>
            </div>
            <div class="flex gap-4 p-4 glass-surface rounded-2xl">
              <div class="text-2xl">⚡</div>
              <div>
                <h4 class="text-white font-bold">Hot-Loading Persistence</h4>
                <p class="text-sm text-zinc-500">Instant extraction and activation of new agent roles.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="flex-1 w-full relative group">
           <div class="absolute inset-0 bg-emerald-500/10 blur-3xl rounded-full opacity-50 group-hover:opacity-100 transition-opacity"></div>
           <img src="/Tadpole-Marketing/assets/sovereign_vault_viz_1773353285088.png" alt="Sovereign Vault" class="rounded-2xl border border-white/10 shadow-2xl relative z-10" />
        </div>
       </div>
    </section>

		<!-- Feature Grid (Agent-Friendly / GEO) -->
		<section class="grid md:grid-cols-3 gap-8 py-24 border-t border-white/5 mt-24" id="features">
			<div class="space-y-4 p-8 glass-surface rounded-2xl hover:border-emerald-500/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-24 h-24 bg-emerald-500/5 blur-3xl group-hover:bg-emerald-500/10 transition-colors"></div>
				<div class="w-12 h-12 rounded-xl bg-zinc-900 border border-white/5 flex items-center justify-center group-hover:border-emerald-500/20 transition-colors">
					<span class="font-mono text-zinc-400 text-sm">01</span>
				</div>
				<h3 class="text-xl font-bold text-white">The "AI Rent" Trap</h3>
				<p class="text-zinc-500 text-sm leading-relaxed">Stop renting intelligence from Big Tech. Tadpole OS provides a sovereign vault where your strategy is never used to train competitors.</p>
			</div>
			
			<div class="space-y-4 p-8 glass-surface rounded-2xl hover:border-emerald-500/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-24 h-24 bg-emerald-500/5 blur-3xl group-hover:bg-emerald-500/10 transition-colors"></div>
				<div class="w-12 h-12 rounded-xl bg-zinc-900 border border-white/5 flex items-center justify-center group-hover:border-emerald-500/20 transition-colors">
					<span class="font-mono text-zinc-400 text-sm">02</span>
				</div>
				<h3 class="text-xl font-bold text-white">Zero-Trust Security</h3>
				<p class="text-zinc-500 text-sm leading-relaxed">Built with **Rust** for memory safety and **NeuralVault** encryption. **Sapphire Shield** protocols ensure total host isolation.</p>
			</div>

			<div class="space-y-4 p-8 glass-surface rounded-2xl hover:border-emerald-500/30 transition-all group relative overflow-hidden">
        <div class="absolute -right-8 -top-8 w-24 h-24 bg-emerald-500/5 blur-3xl group-hover:bg-emerald-500/10 transition-colors"></div>
				<div class="w-12 h-12 rounded-xl bg-zinc-900 border border-white/5 flex items-center justify-center group-hover:border-emerald-500/20 transition-colors">
					<span class="font-mono text-zinc-400 text-sm">03</span>
				</div>
				<h3 class="text-xl font-bold text-white">Shared Prosperity</h3>
				<p class="text-zinc-500 text-sm leading-relaxed">Automate the "drudgery" to secure the value. Use AI-driven growth to reward and secure the humans who built your company.</p>
			</div>
		</section>

    <!-- Executive Q&A (Strategic FAQ) -->
    <section class="max-w-4xl mx-auto py-32 space-y-16">
      <div class="text-center space-y-4">
        <h2 class="text-3xl font-bold text-white">Executive Strategy Q&A</h2>
        <p class="text-zinc-500 font-mono text-xs uppercase tracking-widest">Sovereign Intelligence Briefing</p>
      </div>
      
      <div class="space-y-12">
        <div class="space-y-4 border-l-2 border-emerald-500/20 pl-8 group">
          <h4 class="font-bold text-zinc-100 text-lg group-hover:text-emerald-400 transition-colors tracking-tight">Q: Why do we need Tadpole OS instead of generic AI?</h4>
          <p class="text-zinc-500 leading-relaxed font-light">A: Generic AI is a rental. Tadpole OS is an asset. It creates a **private parallel brain** for your company that you own, control, and evolve without feeding your proprietary secrets to third-party models.</p>
        </div>

        <div class="space-y-4 border-l-2 border-zinc-800 pl-8 group">
          <h4 class="font-bold text-zinc-100 text-lg group-hover:text-emerald-400 transition-colors tracking-tight">Q: How does the "Sapphire Shield" protect us?</h4>
          <p class="text-zinc-500 leading-relaxed font-light">A: The **Sapphire Shield** is an automated security gate that flags high-risk tool calls (like `shell:execute` or `budget:spend`) for mandatory human oversight, preventing autonomous drift.</p>
        </div>

        <div class="space-y-4 border-l-2 border-emerald-500/20 pl-8 group">
          <h4 class="font-bold text-zinc-100 text-lg group-hover:text-emerald-400 transition-colors tracking-tight">Q: Is a "Parallel OS" disruptive to current IT?</h4>
          <p class="text-zinc-500 leading-relaxed font-light">A: No. Tadpole OS is designed to integrate via the **Model Context Protocol (MCP)** and standard REST protocols, assists your current workflows without "rip and replace" friction.</p>
        </div>
      </div>
    </section>

    <!-- Onboarding Funnel (Hierarchy) -->
    <section class="py-24 glass-surface rounded-3xl p-12 text-center space-y-12 relative overflow-hidden">
      <div class="absolute inset-0 bg-emerald-500/5 blur-3xl pointer-events-none"></div>
      <div class="space-y-4 relative">
        <h2 class="text-3xl font-bold text-white">Ready for the Leap?</h2>
        <p class="text-zinc-400 max-w-xl mx-auto font-light">Three tiered entry points to sovereign intelligence.</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6 relative">
        <div class="p-6 rounded-2xl bg-zinc-950/50 border border-white/5 flex flex-col justify-between">
          <div class="space-y-2">
            <h4 class="text-emerald-400 font-mono text-[10px] tracking-widest uppercase">Tier 1</h4>
            <h5 class="text-white font-bold">Instant Demo</h5>
            <p class="text-xs text-zinc-500 leading-relaxed">Read-only interactive swarm for CEO-level ROI verification.</p>
          </div>
          <button class="mt-6 text-xs font-bold text-zinc-400 hover:text-white transition-colors">Start Demo →</button>
        </div>
        
        <div class="p-6 rounded-2xl bg-zinc-950/50 border border-emerald-500/20 flex flex-col justify-between relative ring-1 ring-emerald-500/10">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-emerald-500 text-zinc-950 text-[8px] font-bold px-2 py-0.5 rounded-full uppercase tracking-widest">Recommended</div>
          <div class="space-y-2">
            <h4 class="text-emerald-400 font-mono text-[10px] tracking-widest uppercase">Tier 2</h4>
            <h5 class="text-white font-bold">Sandbox Pilot</h5>
            <p class="text-xs text-zinc-500 leading-relaxed">One-click Windows Sandbox download for isolated testing.</p>
          </div>
          <button class="mt-6 text-xs font-bold text-emerald-400">Download Pilot →</button>
        </div>

        <div class="p-6 rounded-2xl bg-zinc-950/50 border border-white/5 flex flex-col justify-between">
          <div class="space-y-2">
            <h4 class="text-emerald-400 font-mono text-[10px] tracking-widest uppercase">Tier 3</h4>
            <h5 class="text-white font-bold">Swarm Bunker</h5>
            <p class="text-xs text-zinc-500 leading-relaxed">Full-scale production deployment on local infrastructure.</p>
          </div>
          <button class="mt-6 text-xs font-bold text-zinc-400 hover:text-white transition-colors">Contact Sales →</button>
        </div>
      </div>
    </section>

    <footer class="mt-32 pt-12 border-t border-white/5 text-center space-y-4 pb-12">
      <p class="text-zinc-600 font-mono text-[10px] tracking-[0.4em] uppercase">
        © 2026 Tadpole OS Engine | Sovereign Intelligence Trademarked
      </p>
      <p class="text-zinc-800 text-[9px] font-mono uppercase tracking-widest">
        All Strategic Directives Protected by Entity 0 Approval Protocols
      </p>
    </footer>
	</main>

  <!-- JSON-LD for AI Search Engines (GEO) -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Tadpole OS",
      "applicationCategory": "AI Operating System",
      "operatingSystem": "Cross-platform (Rust Runtime)",
      "description": "A high-performance, local-first engine for sovereign multi-agent swarms.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "Tadpole OS Project"
      }
    }
  </script>
</BaseLayout>
